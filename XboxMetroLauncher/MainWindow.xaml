                                  HorizontalScrollBarVisibility="Disabled"
                                  Focusable="False"
                                  PanningMode="VerticalOnly">
                        <StackPanel>
                            <TextBlock Text="Theme name" Foreground="#FF333333" FontSize="18" />
                            <TextBox Text="{Binding ThemeNameInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,8,0,14" />
                            <TextBlock Text="1. Choose Home background" Foreground="#FF333333" FontSize="18" />
                            <Button x:Name="ChooseThemeHomeBackgroundButton" Content="Choose Home background" Style="{StaticResource SettingsActionButtonStyle}" Margin="0,8,0,14" Command="{Binding ChooseThemeHomeImageCommand}" />
                            <TextBlock Text="2. Choose My Games/My Pins background" Foreground="#FF333333" FontSize="18" />
                            <Button Content="Choose My Games/My Pins background" Style="{StaticResource SettingsActionButtonStyle}" Margin="0,8,0,14" Command="{Binding ChooseThemeGamesImageCommand}" />
                            <TextBlock Text="3. Choose Settings background" Foreground="#FF333333" FontSize="18" />
                            <Button Content="Choose Settings background" Style="{StaticResource SettingsActionButtonStyle}" Margin="0,8,0,14" Command="{Binding ChooseThemeSettingsImageCommand}" />
                            <TextBlock Text="4. Choose Apps/My Apps background" Foreground="#FF333333" FontSize="18" />
                            <Button Content="Choose Apps/My Apps background" Style="{StaticResource SettingsActionButtonStyle}" Margin="0,8,0,12" Command="{Binding ChooseThemeAppsImageCommand}" />
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="1" Grid.Column="1" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Margin="10">
                            <TextBlock Text="Home preview" Foreground="#FF333333" FontSize="18" Margin="0,0,0,8" />
                            <Border Height="170" Background="#FF9A9A9A" BorderBrush="#99FFFFFF" BorderThickness="1">
                                <Image Source="{Binding ThemeHomePreviewPath, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=640}"
                                       Stretch="UniformToFill" />
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10">
                            <TextBlock Text="My Games/My Pins preview" Foreground="#FF333333" FontSize="18" Margin="0,0,0,8" />
                            <Border Height="170" Background="#FF9A9A9A" BorderBrush="#99FFFFFF" BorderThickness="1">
                                <Image Source="{Binding ThemeGamesPreviewPath, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=640}"
                                       Stretch="UniformToFill" />
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Margin="10">
                            <TextBlock Text="Settings preview" Foreground="#FF333333" FontSize="18" Margin="0,0,0,8" />
                            <Border Height="170" Background="#FF9A9A9A" BorderBrush="#99FFFFFF" BorderThickness="1">
                                <Image Source="{Binding ThemeSettingsPreviewPath, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=640}"
                                       Stretch="UniformToFill" />
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="10">
                            <TextBlock Text="Apps/My Apps preview" Foreground="#FF333333" FontSize="18" Margin="0,0,0,8" />
                            <Border Height="170" Background="#FF9A9A9A" BorderBrush="#99FFFFFF" BorderThickness="1">
                                <Image Source="{Binding ThemeAppsPreviewPath, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=640}"
                                       Stretch="UniformToFill" />
                            </Border>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                        <Button Content="Save Theme" Style="{StaticResource SettingsActionButtonStyle}" Width="180" Margin="0,0,10,0" Command="{Binding SaveThemeCommand}" />
                        <Button Content="Back" Style="{StaticResource SettingsActionButtonStyle}" Width="140" Command="{Binding CloseThemeCreatorCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="92,0,0,45">
                <Border Width="18" Height="18" CornerRadius="9" Background="#FF6CB344"><TextBlock Text="A" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                <TextBlock Text=" Select   " Foreground="White" FontSize="15" />
                <Border Width="18" Height="18" CornerRadius="9" Background="#FFD73A3A"><TextBlock Text="B" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                <TextBlock Text=" Back" Foreground="White" FontSize="15" />
            </StackPanel>
        </Grid>

        <Grid x:Name="SteamSetupOverlay"
              FocusManager.IsFocusScope="True"
              KeyboardNavigation.DirectionalNavigation="Cycle"
              KeyboardNavigation.TabNavigation="Cycle"
              Visibility="{Binding IsSteamSetupOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Rectangle Fill="#77000000" />
            <Border Width="760"
                    Height="500"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#F1F4F4F4"
                    BorderBrush="#88FFFFFF"
                    BorderThickness="1">
                <Grid Margin="26">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Steam Setup"
                                   Foreground="#FF333333"
                                   FontSize="30"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Connect Steam friends and Guide achievements. This saves only to this app copy's UserData folder."
                                   Foreground="#FF555555"
                                   FontSize="16"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,22,0,0"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Focusable="False"
                                  PanningMode="VerticalOnly">
                        <StackPanel>
                            <TextBlock Text="SteamID64"
                                       Foreground="#FF333333"
                                       FontSize="18" />
                            <DockPanel Margin="0,8,0,16">
                                <Button Content="Paste"
                                        Style="{StaticResource SettingsActionButtonStyle}"
                                        Width="110"
                                        Margin="10,0,0,0"
                                        DockPanel.Dock="Right"
                                        Command="{Binding PasteSteamIdCommand}" />
                                <TextBox Text="{Binding SteamSetupSteamId64, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Height="42"
                                         FontSize="20"
                                         VerticalContentAlignment="Center" />
                            </DockPanel>

                            <TextBlock Text="Steam Web API key"
                                       Foreground="#FF333333"
                                       FontSize="18" />
                            <DockPanel Margin="0,8,0,16">
                                <Button Content="Paste"
                                        Style="{StaticResource SettingsActionButtonStyle}"
                                        Width="110"
                                        Margin="10,0,0,0"
                                        DockPanel.Dock="Right"
                                        Command="{Binding PasteSteamApiKeyCommand}" />
                                <TextBox Text="{Binding SteamSetupApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Height="42"
                                         FontSize="20"
                                         VerticalContentAlignment="Center" />
                            </DockPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                <Button Content="Get API Key"
                                        Style="{StaticResource SettingsActionButtonStyle}"
                                        Width="170"
                                        Margin="0,0,10,0"
                                        Command="{Binding OpenSteamApiKeyPageCommand}" />
                                <Button Content="Find SteamID64"
                                        Style="{StaticResource SettingsActionButtonStyle}"
                                        Width="180"
                                        Command="{Binding OpenSteamProfileHelpCommand}" />
                            </StackPanel>

                            <Border Background="#22FFFFFF"
                                    BorderBrush="#55FFFFFF"
                                    BorderThickness="1"
                                    Padding="14"
                                    Margin="0,0,0,8">
                                <TextBlock Text="{Binding SteamSetupStatus}"
                                           Foreground="#FF333333"
                                           FontSize="17"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,20,0,0">
                        <Button Content="Test Connection"
                                Style="{StaticResource SettingsActionButtonStyle}"
                                Width="190"
                                Margin="0,0,10,0"
                                Command="{Binding TestSteamSetupCommand}" />
                        <Button Content="Save"
                                Style="{StaticResource SettingsActionButtonStyle}"
                                Width="140"
                                Margin="0,0,10,0"
                                Command="{Binding SaveSteamSetupCommand}" />
                        <Button Content="Back"
                                Style="{StaticResource SettingsActionButtonStyle}"
                                Width="130"
                                Command="{Binding CloseSteamSetupCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="92,0,0,45">
                <Border Width="18" Height="18" CornerRadius="9" Background="#FF6CB344"><TextBlock Text="A" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                <TextBlock Text=" Select   " Foreground="White" FontSize="15" />
                <Border Width="18" Height="18" CornerRadius="9" Background="#FFD73A3A"><TextBlock Text="B" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                <TextBlock Text=" Back" Foreground="White" FontSize="15" />
            </StackPanel>
        </Grid>

        <Grid x:Name="MusicPlayerOverlay"
              FocusManager.IsFocusScope="True"
              KeyboardNavigation.DirectionalNavigation="Cycle"
              KeyboardNavigation.TabNavigation="Cycle"
              Visibility="{Binding IsMusicPlayerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.Resources>
                <Style x:Key="MusicPlayerButtonStyle" TargetType="{x:Type Button}">
                    <Setter Property="Foreground" Value="#FF333333" />
                    <Setter Property="Background" Value="#FFE8ECEC" />
                    <Setter Property="BorderBrush" Value="#55FFFFFF" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="FontSize" Value="17" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="4,0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border x:Name="Root"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="1">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="Background" Value="#FF5EAE19" />
                                        <Setter Property="BorderBrush" Value="White" />
                                        <Setter Property="BorderThickness" Value="2" />
                                        <Setter TargetName="Root" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="White" Opacity="0.35" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="Background" Value="#FF5EAE19" />
                                        <Setter Property="BorderBrush" Value="White" />
                                        <Setter Property="BorderThickness" Value="2" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#FF3F8610" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style x:Key="MusicTrackButtonStyle" TargetType="{x:Type Button}">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Grid>
                                    <ContentPresenter />
                                    <Border x:Name="FocusFrame"
                                            BorderBrush="#FF5EAE19"
                                            BorderThickness="4"
                                            Opacity="0" />
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter TargetName="FocusFrame" Property="Opacity" Value="1" />
                                        <Setter Property="Panel.ZIndex" Value="10" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Opacity" Value="0.82" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>
            <Grid.Style>
                <Style TargetType="{x:Type Grid}">
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#F0060708" Offset="0" />
                                <GradientStop Color="#EA161A1C" Offset="0.55" />
                                <GradientStop Color="#F0020203" Offset="1" />
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMusicPlayerTransparent}" Value="True">
                            <Setter Property="Background" Value="Transparent" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsMusicVisualizerFullscreen}" Value="True">
                            <Setter Property="Background" Value="#F4000000" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <TextBlock Text="Now Playing" Foreground="#F2FFFFFF" FontSize="32" FontWeight="Light" Margin="148,52,0,0">
                <TextBlock.Style>
                    <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMusicVisualizerFullscreen}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Grid x:Name="MusicPlayerContentGrid" Width="880" Height="482" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.Style>
                    <Style TargetType="{x:Type Grid}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMusicVisualizerFullscreen}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="440" />
                    <ColumnDefinition Width="440" />
                </Grid.ColumnDefinitions>

                <Border Background="#EEF0F2F1" />
                <Border Grid.Column="1" Background="#D9AEB4B7" />

                <StackPanel Margin="26,18,26,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Width="58" Height="38" Content="{Binding MusicPlayPauseText}"
                                Style="{StaticResource MusicPlayerButtonStyle}" Command="{Binding PlayPauseMusicCommand}" />
                        <Button Width="58" Height="38" Content="Prev" Margin="5,0,0,0"
                                Style="{StaticResource MusicPlayerButtonStyle}" Command="{Binding PreviousMusicCommand}" />
                        <Button Width="58" Height="38" Content="Stop" Margin="5,0,0,0"
                                Style="{StaticResource MusicPlayerButtonStyle}" Command="{Binding StopMusicCommand}" />
                        <Button Width="58" Height="38" Content="Next" Margin="5,0,0,0"
                                Style="{StaticResource MusicPlayerButtonStyle}" Command="{Binding NextMusicCommand}" />
                        <Button Width="82" Height="38" Content="{Binding ShuffleText}" Margin="5,0,0,0"
                                Style="{StaticResource MusicPlayerButtonStyle}" Command="{Binding ToggleShuffleMusicCommand}" />
                    </StackPanel>

                    <TextBlock Text="Edit or Save Playlist" Foreground="#FF55595C" FontSize="22" Margin="0,20,0,14" />
                    <TextBlock Text="{Binding CurrentMusicTitle}" Foreground="#FF55595C" FontSize="21" TextTrimming="CharacterEllipsis" Margin="0,22,0,8" />
                    <Grid Height="44">
                        <Border Height="8" Background="#FFB5BABB" VerticalAlignment="Top" Margin="0,8,0,0" />
                        <ProgressBar Height="8" Minimum="0" Maximum="100" Value="{Binding MusicProgress}" Foreground="#FF6D7173" Background="Transparent" BorderThickness="0" VerticalAlignment="Top" Margin="0,8,0,0" />
                        <TextBlock Text="{Binding MusicPositionText}" Foreground="#FF55595C" FontSize="16" HorizontalAlignment="Left" VerticalAlignment="Bottom" />
                        <TextBlock Text="{Binding MusicDurationText}" Foreground="#FF55595C" FontSize="16" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
                    </Grid>

                    <Grid Margin="0,24,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="128" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="96" />
                        </Grid.RowDefinitions>

                        <Border ClipToBounds="True">
                            <controls:MusicVisualizer IsActive="{Binding IsMusicPlaying}"
                                                      Volume="{Binding MusicVolume}"
                                                      Progress="{Binding MusicProgress}"
                                                      Bass="{Binding VisualizerBass}"
                                                      Mid="{Binding VisualizerMid}"
                                                      Treble="{Binding VisualizerTreble}"
                                                      Loudness="{Binding VisualizerLoudness}"
                                                      Peak="{Binding VisualizerPeak}" />
                        </Border>

                        <Border Grid.Row="2" Background="#FFE2E5E4">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="Music Files" Foreground="#FF6B7174" FontSize="22" FontWeight="Light" HorizontalAlignment="Center" />
                                <TextBlock Text="Assets\Custom Files\Music Files" Foreground="#FF7D8385" FontSize="13" Margin="0,6,0,0" HorizontalAlignment="Center">
                                    <TextBlock.InputBindings>
                                        <MouseBinding MouseAction="LeftClick" Command="{Binding OpenMusicFolderCommand}" />
                                    </TextBlock.InputBindings>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                    <TextBlock Text="{Binding MusicVolumeText, StringFormat=Volume {0}}" Foreground="#FF7D8385" FontSize="15" VerticalAlignment="Center" Margin="0,0,12,0" />
                                    <Button Width="68" Height="28" Content="Vol -"
                                            Style="{StaticResource MusicPlayerButtonStyle}" Command="{Binding VolumeDownCommand}" />
                                    <Button Width="68" Height="28" Content="Vol +" Margin="8,0,0,0"
                                            Style="{StaticResource MusicPlayerButtonStyle}" Command="{Binding VolumeUpCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <Grid Grid.Column="1" Margin="0,12,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding MusicTracks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Height="48"
                                            Style="{StaticResource MusicTrackButtonStyle}"
                                            Command="{Binding DataContext.PlaySelectedMusicCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}">
                                        <Grid Background="#21FFFFFF">
                                            <TextBlock Text="{Binding Title}" Foreground="#FF5F6669" FontSize="21" Margin="30,0,24,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="playing" Foreground="#FF5EAE19" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,18,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="{x:Type TextBlock}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <TextBlock Text="{Binding MusicTrackCountText}" Foreground="#FF5F6669" FontSize="15" VerticalAlignment="Bottom" Margin="30,0,0,24" />
                </Grid>
            </Grid>

            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                  Visibility="{Binding IsMusicVisualizerFullscreen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <controls:MusicVisualizer IsActive="{Binding IsMusicPlaying}"
                                          Volume="{Binding MusicVolume}"
                                          Progress="{Binding MusicProgress}"
                                          Bass="{Binding VisualizerBass}"
                                          Mid="{Binding VisualizerMid}"
                                          Treble="{Binding VisualizerTreble}"
                                          Loudness="{Binding VisualizerLoudness}"
                                          Peak="{Binding VisualizerPeak}" />
            </Grid>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="145,0,0,58">
                <StackPanel.Style>
                    <Style TargetType="{x:Type StackPanel}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsMusicVisualizerFullscreen}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <Border Width="18" Height="18" CornerRadius="9" Background="#FF6CB344"><TextBlock Text="A" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                <TextBlock Text=" Select   " Foreground="#E6FFFFFF" FontSize="15" />
                <Border Width="18" Height="18" CornerRadius="9" Background="#FFD73A3A"><TextBlock Text="B" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                <TextBlock Text=" Back   " Foreground="#E6FFFFFF" FontSize="15" />
                <Grid Background="Transparent"
                      Cursor="Hand"
                      Margin="0"
                      MouseLeftButtonUp="MusicFullscreenHint_OnMouseLeftButtonUp">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="18" Height="18" CornerRadius="9" Background="#FF2574AA"><TextBlock Text="X" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                        <TextBlock Text=" Fullscreen Visualizer" Foreground="#E6FFFFFF" FontSize="16" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Grid>

        <Grid x:Name="ProfileEditorOverlay"
              Visibility="{Binding IsProfileEditorOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#E9000000" Offset="0" />
                    <GradientStop Color="#D20B0E0F" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <TextBlock Text="Profile" Foreground="White" FontSize="18" Margin="138,38,0,0" />
            <TextBlock Text="{Binding ClockText}" Foreground="#E8FFFFFF" FontSize="18" HorizontalAlignment="Right" Margin="0,36,138,0" VerticalAlignment="Top" />
            <Grid Width="760" Height="402" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330" />
                    <ColumnDefinition Width="430" />
                </Grid.ColumnDefinitions>
                <Border Background="#EEF4F6F5" />
                <Border Grid.Column="1" Background="#D35D686D" />
                <StackPanel>
                    <Border Height="36" Background="#F8FFFFFF">
                        <TextBlock Text="View Games" Foreground="#FF222222" FontSize="17" Margin="18,0,0,0" VerticalAlignment="Center" />
                    </Border>
                    <Border Height="36" Background="#FF008A00">
                        <TextBlock Text="Edit Profile" Foreground="White" FontSize="17" Margin="18,0,0,0" VerticalAlignment="Center" />
                    </Border>
                    <Border Height="36" Background="#F8FFFFFF">
                        <TextBlock Text="View Rep" Foreground="#FF222222" FontSize="17" Margin="18,0,0,0" VerticalAlignment="Center" />
                    </Border>
                    <Border Height="36" Background="#F8FFFFFF">
                        <TextBlock Text="Game Defaults" Foreground="#FF222222" FontSize="17" Margin="18,0,0,0" VerticalAlignment="Center" />
                    </Border>
                    <Border Height="36" Background="#F8FFFFFF">
                        <TextBlock Text="Sign-in Preferences" Foreground="#FF222222" FontSize="17" Margin="18,0,0,0" VerticalAlignment="Center" />
                    </Border>
                    <Border Height="36" Background="#F8FFFFFF">
                        <TextBlock Text="Account Security" Foreground="#FF222222" FontSize="17" Margin="18,0,0,0" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
                <Grid Grid.Column="1">
                    <Border Height="72" VerticalAlignment="Top" Background="#F8FFFFFF" Margin="10,10,10,0">
                        <StackPanel Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                            <Button Width="52" Height="52"
                                    Style="{StaticResource X360TileButtonStyle}"
                                    Command="{Binding ChooseProfilePictureCommand}"
                                    ToolTip="Change gamer picture">
                                <Image Source="{Binding Profile.GamerPicturePath, Converter={StaticResource StringToImageSourceConverter}}"
                                       Stretch="UniformToFill" />
                            </Button>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Profile.Gamertag}" Foreground="#FF1F1F1F" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Profile.OnlineStatus}" Foreground="#FF555555" FontSize="13" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Margin="28,98,28,0">
                        <TextBlock Text="Username" Foreground="White" FontSize="16" />
                        <TextBox Text="{Binding Profile.Gamertag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MetroTextBoxStyle}" Margin="0,5,0,12" />
                        <TextBlock Text="Motto" Foreground="White" FontSize="16" />
                        <TextBox Text="{Binding Profile.Motto, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MetroTextBoxStyle}" Margin="0,5,0,12" />
                        <TextBlock Text="Description" Foreground="White" FontSize="16" />
                        <TextBox Text="{Binding Profile.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MetroTextBoxStyle}" Height="70" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,12" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Change Picture" Width="148" Style="{StaticResource MetroActionButtonStyle}" Command="{Binding ChooseProfilePictureCommand}" />
                            <Button Content="Save" Width="112" Margin="10,0,0,0" Style="{StaticResource MetroActionButtonStyle}" Command="{Binding SaveProfileCommand}" />
                            <Button Content="Back" Width="112" Margin="10,0,0,0" Style="{StaticResource MetroActionButtonStyle}" Command="{Binding CloseProfileEditorCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="138,0,0,38">
                <Border Width="18" Height="18" CornerRadius="9" Background="#FF6CB344"><TextBlock Text="A" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                <TextBlock Text=" Select   " Foreground="White" FontSize="15" />
                <Border Width="18" Height="18" CornerRadius="9" Background="#FFD73A3A"><TextBlock Text="B" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                <TextBlock Text=" Back" Foreground="White" FontSize="15" />
            </StackPanel>
        </Grid>

    </Grid>
    </Viewbox>

    <Grid x:Name="BootOverlay" Background="White"
          Visibility="{Binding IsBooting, Converter={StaticResource BooleanToVisibilityConverter}}">
        <wfi:WindowsFormsHost x:Name="BootVideoHost" />
        <Viewbox Stretch="Uniform" IsHitTestVisible="False" Visibility="Collapsed">
            <Canvas Width="1280" Height="720">
                <TextBlock Canvas.Left="902"
                           Canvas.Top="430"
                           Text="®"
                           FontFamily="Segoe UI"
                           FontSize="18"
                           Foreground="#FF9C9C9C"
                           Opacity="0.85" />
            </Canvas>
        </Viewbox>
    </Grid>
    </Grid>
</Window>
