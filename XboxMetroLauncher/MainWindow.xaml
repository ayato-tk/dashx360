<Window x:Class="XboxMetroLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:controls="clr-namespace:XboxMetroLauncher.Controls"
        Title="Xbox Metro Launcher"
        Width="1280"
        Height="720"
        MinWidth="1024"
        MinHeight="576"
        Background="{StaticResource DashboardBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        PreviewMouseDown="Window_OnPreviewMouseDown"
        PreviewMouseMove="Window_OnPreviewMouseMove"
        Loaded="Window_OnLoaded"
        Closing="Window_OnClosing">
    <Window.Resources>
        <Style x:Key="SettingsFocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Border Margin="-4"
                                BorderBrush="White"
                                BorderThickness="2"
                                CornerRadius="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14"
                                                  ShadowDepth="0"
                                                  Color="#FF79D544"
                                                  Opacity="0.75" />
                            </Border.Effect>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsActionButtonStyle"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource MetroActionButtonStyle}">
            <Setter Property="FocusVisualStyle" Value="{StaticResource SettingsFocusVisual}" />
            <Setter Property="BorderBrush" Value="#88FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="#FF008A00" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderBrush" Value="White" />
                    <Setter Property="BorderThickness" Value="2" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Background="#FF0B0F0B">
    <Grid x:Name="AudioHost"
          Width="1"
          Height="1"
          Opacity="0"
          IsHitTestVisible="False"
          HorizontalAlignment="Left"
          VerticalAlignment="Top" />
    <Viewbox Stretch="Uniform">
    <Grid x:Name="RootGrid" Width="1280" Height="720" ClipToBounds="True" Background="{StaticResource DashboardBackgroundBrush}">
        <Grid x:Name="ThemeBackgroundLayer"
              Opacity="0"
              Visibility="Collapsed"
              IsHitTestVisible="False">
            <Image x:Name="ThemeBackgroundImage"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <Rectangle Fill="#33000000" />
        </Grid>
        <Grid x:Name="BingBackgroundLayer"
              Opacity="0"
              Visibility="Collapsed"
              IsHitTestVisible="False">
            <Image x:Name="BingBackgroundImage"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <Rectangle Fill="#18000000" />
        </Grid>
        <Rectangle Opacity="0.08">
            <Rectangle.Fill>
                <RadialGradientBrush Center="0.28,0.22" RadiusX="0.85" RadiusY="0.7">
                    <GradientStop Color="#CCFFFFFF" Offset="0" />
                    <GradientStop Color="#66FFFFFF" Offset="0.45" />
                    <GradientStop Color="#00FFFFFF" Offset="1" />
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid>
            <Grid.Style>
                <Style TargetType="{x:Type Grid}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBooting}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsDashboardContentHidden}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="146" />
                <RowDefinition Height="*" />
                <RowDefinition Height="72" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Canvas Margin="0,112,0,0" Height="46" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                        IsHitTestVisible="False" Opacity="0.12" Visibility="Collapsed">
                    <TextBlock Canvas.Left="180" Width="58" Height="40" Text="bing" Style="{StaticResource TabGhostTextStyle}" />
                    <TextBlock Canvas.Left="262" Width="78" Height="40" Text="home" Style="{StaticResource TabGhostTextStyle}" />
                    <TextBlock Canvas.Left="366" Width="86" Height="40" Text="social" Style="{StaticResource TabGhostTextStyle}" />
                    <TextBlock Canvas.Left="480" Width="82" Height="40" Text="video" Style="{StaticResource TabGhostTextStyle}" />
                    <TextBlock Canvas.Left="602" Width="94" Height="40" Text="games" Style="{StaticResource TabGhostTextStyle}" />
                    <TextBlock Canvas.Left="744" Width="88" Height="40" Text="music" Style="{StaticResource TabGhostTextStyle}" />
                    <TextBlock Canvas.Left="854" Width="68" Height="40" Text="apps" Style="{StaticResource TabGhostTextStyle}" />
                    <TextBlock Canvas.Left="942" Width="128" Height="40" Text="settings" Style="{StaticResource TabGhostTextStyle}" />
                </Canvas>
                <Canvas Margin="0,96,0,0" Height="46" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                        Visibility="{Binding IsMyGamesOpen, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <Button Canvas.Left="180" Canvas.Top="0" Width="58" Height="40" Content="bing" DataContext="{Binding Tabs[0]}"
                            Style="{StaticResource TabButtonStyle}"
                            Command="{Binding DataContext.SwitchTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" />
                    <Button Canvas.Left="262" Canvas.Top="0" Width="78" Height="40" Content="home" DataContext="{Binding Tabs[1]}"
                            Style="{StaticResource TabButtonStyle}"
                            Command="{Binding DataContext.SwitchTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" />
                    <Button Canvas.Left="366" Canvas.Top="0" Width="86" Height="40" Content="social" DataContext="{Binding Tabs[2]}"
                            Style="{StaticResource TabButtonStyle}"
                            Command="{Binding DataContext.SwitchTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" />
                    <Button Canvas.Left="480" Canvas.Top="0" Width="82" Height="40" Content="video" DataContext="{Binding Tabs[3]}"
                            Style="{StaticResource TabButtonStyle}"
                            Command="{Binding DataContext.SwitchTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" />
                    <Button Canvas.Left="602" Canvas.Top="0" Width="94" Height="40" Content="games" DataContext="{Binding Tabs[4]}"
                            Style="{StaticResource TabButtonStyle}"
                            Command="{Binding DataContext.SwitchTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" />
                    <Button Canvas.Left="744" Canvas.Top="0" Width="88" Height="40" Content="music" DataContext="{Binding Tabs[5]}"
                            Style="{StaticResource TabButtonStyle}"
                            Command="{Binding DataContext.SwitchTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" />
                    <Button Canvas.Left="854" Canvas.Top="0" Width="68" Height="40" Content="apps" DataContext="{Binding Tabs[6]}"
                            Style="{StaticResource TabButtonStyle}"
                            Command="{Binding DataContext.SwitchTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" />
                    <Button Canvas.Left="942" Canvas.Top="0" Width="128" Height="40" Content="settings" DataContext="{Binding Tabs[7]}"
                            Style="{StaticResource TabButtonStyle}"
                            Command="{Binding DataContext.SwitchTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}" />
                </Canvas>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,72,70,0"
                            Opacity="0.82">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0">
                        <TextBlock Text="{Binding Profile.Gamertag}"
                                   Foreground="#F2FFFFFF"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextAlignment="Right"
                                   HorizontalAlignment="Right" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,-1,0,0">
                            <TextBlock Text="{Binding Profile.OnlineStatus}" Foreground="#C8FFFFFF" FontSize="10" />
                        </StackPanel>
                    </StackPanel>
                    <Border Width="24"
                            Height="24"
                            Background="{StaticResource MetroGreenBrush}"
                            ClipToBounds="True">
                        <Image Source="{Binding Profile.GamerPicturePath, Converter={StaticResource StringToImageSourceConverter}}"
                               Stretch="UniformToFill"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Grid>

            <Grid x:Name="ContentFrame"
                  Grid.Row="1"
                  Width="1280"
                  Height="502"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  ClipToBounds="True">
                <ContentControl x:Name="ContentHost"
                                Width="1280"
                                Height="502"
                                Panel.ZIndex="2"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Content="{Binding CurrentTab}">
                    <ContentControl.RenderTransform>
                        <TranslateTransform x:Name="ContentSlide" X="0" />
                    </ContentControl.RenderTransform>
                </ContentControl>
                <Canvas x:Name="TabTransitionLayer"
                        Width="1280"
                        Height="502"
                        Panel.ZIndex="60"
                        Visibility="Collapsed"
                        ClipToBounds="True"
                        IsHitTestVisible="False"
                        Focusable="False">
                    <Canvas x:Name="TabTransitionStrip"
                            Width="3840"
                            Height="502">
                        <Canvas.RenderTransform>
                            <TranslateTransform x:Name="TabTransitionSlide" X="-1280" />
                        </Canvas.RenderTransform>
                        <ContentControl x:Name="TransitionLeftHost"
                                        Width="1280"
                                        Height="502"
                                        Canvas.Left="0"
                                        Canvas.Top="0"
                                        IsHitTestVisible="False"
                                        Focusable="False" />
                        <ContentControl x:Name="TransitionCenterHost"
                                        Width="1280"
                                        Height="502"
                                        Canvas.Left="1280"
                                        Canvas.Top="0"
                                        IsHitTestVisible="False"
                                        Focusable="False" />
                        <ContentControl x:Name="TransitionRightHost"
                                        Width="1280"
                                        Height="502"
                                        Canvas.Left="2560"
                                        Canvas.Top="0"
                                        IsHitTestVisible="False"
                                        Focusable="False" />
                    </Canvas>
                </Canvas>
                <Canvas x:Name="AdjacentPreviewLayer"
                        Width="1280"
                        Height="502"
                        IsHitTestVisible="False"
                        Opacity="0.36"
                        Panel.ZIndex="80"
                        ClipToBounds="True">
                    <Border Canvas.Left="0"
                            Canvas.Top="0"
                            Width="104"
                            Height="502"
                            ClipToBounds="True">
                        <Grid Width="104"
                              Height="502"
                              IsHitTestVisible="False">
                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="PreviousPreviewOffset" X="0" />
                            </Grid.RenderTransform>
                            <Image x:Name="PreviousPreviewImage"
                                   Width="104"
                                   Height="502"
                                   Stretch="Fill"
                                   SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="LowQuality"
                                   IsHitTestVisible="False" />
                            <Canvas x:Name="PreviousPreviewLiveLayer"
                                    Width="104"
                                    Height="502"
                                    Visibility="Collapsed"
                                    ClipToBounds="True">
                                <ContentControl x:Name="PreviousPreviewLiveHost"
                                                Width="1280"
                                                Height="502"
                                                Canvas.Left="{Binding LeftPreviewContentLeft}"
                                                Canvas.Top="0"
                                                IsHitTestVisible="False"
                                                Focusable="False" />
                            </Canvas>
                        </Grid>
                    </Border>
                    <Border Canvas.Left="1160"
                            Canvas.Top="0"
                            Width="104"
                            Height="502"
                            ClipToBounds="True">
                        <Grid Width="104"
                              Height="502"
                              IsHitTestVisible="False">
                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="NextPreviewOffset" X="0" />
                            </Grid.RenderTransform>
                            <Image x:Name="NextPreviewImage"
                                   Width="104"
                                   Height="502"
                                   Stretch="Fill"
                                   SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="LowQuality"
                                   IsHitTestVisible="False" />
                            <Canvas x:Name="NextPreviewLiveLayer"
                                    Width="104"
                                    Height="502"
                                    Visibility="Collapsed"
                                    ClipToBounds="True">
                                <ContentControl x:Name="NextPreviewLiveHost"
                                                Width="1280"
                                                Height="502"
                                                Canvas.Left="{Binding RightPreviewContentLeft}"
                                                Canvas.Top="0"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center"
                                                IsHitTestVisible="False"
                                                Focusable="False" />
                            </Canvas>
                        </Grid>
                    </Border>
                </Canvas>

                <Canvas x:Name="DebugGuides" Width="1280" Height="502" IsHitTestVisible="False" Visibility="Collapsed">
                    <Rectangle Width="1280" Height="502" Stroke="#99FF00FF" StrokeThickness="2" />
                    <Line X1="0" Y1="0" X2="1280" Y2="0" Stroke="#99FFFF00" StrokeThickness="1" />
                    <Line X1="198" Y1="0" X2="198" Y2="502" Stroke="#9900FFFF" StrokeThickness="1" />
                    <Line X1="0" Y1="74" X2="1280" Y2="74" Stroke="#9900FFFF" StrokeThickness="1" />
                </Canvas>
            </Grid>

            <Grid Grid.Row="2">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="112,16,0,0">
                    <Border Width="18" Height="18" CornerRadius="9" Background="#FF6CB344">
                        <TextBlock Text="A" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text=" Select   " Foreground="White" FontSize="15" />
                    <Border Width="18" Height="18" CornerRadius="9" Background="#FFE0C33C">
                        <TextBlock Text="Y" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text=" Eject" Foreground="White" FontSize="15" />
                </StackPanel>
            </Grid>
        </Grid>

        <Grid x:Name="GameDetailsOverlay"
              Panel.ZIndex="70"
              FocusManager.IsFocusScope="True"
              KeyboardNavigation.DirectionalNavigation="Cycle"
              KeyboardNavigation.TabNavigation="Cycle"
              Visibility="{Binding IsDetailsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.Resources>
                <Style x:Key="GameDetailsTileButtonStyle" TargetType="{x:Type Button}">
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="Background" Value="{StaticResource MetroGreenBrush}" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Padding" Value="16,0,8,17" />
                    <Setter Property="FontFamily" Value="Segoe UI Light" />
                    <Setter Property="FontSize" Value="20" />
                    <Setter Property="FontWeight" Value="Normal" />
                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                    <Setter Property="VerticalContentAlignment" Value="Bottom" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Panel.ZIndex" Value="0" />
                    <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Setter.Value>
                    </Setter>
                    <EventSetter Event="GotKeyboardFocus" Handler="GameDetailsTileButton_OnFocusOrMouseEnter" />
                    <EventSetter Event="MouseEnter" Handler="GameDetailsTileButton_OnFocusOrMouseEnter" />
                    <EventSetter Event="LostKeyboardFocus" Handler="GameDetailsTileButton_OnFocusOrMouseLeave" />
                    <EventSetter Event="MouseLeave" Handler="GameDetailsTileButton_OnFocusOrMouseLeave" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Grid>
                                    <Border x:Name="Root"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#FF00A000" Offset="0" />
                                                <GradientStop Color="#FF008C00" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                          Margin="{TemplateBinding Padding}"
                                                          RecognizesAccessKey="True" />
                                    </Border>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Panel.ZIndex" Value="5" />
                                        <Setter TargetName="Root" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="8" ShadowDepth="5" Direction="315" Opacity="0.32" Color="Black" />
                                            </Setter.Value>
                                        </Setter>
                                        <Setter TargetName="Root" Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#FF20CE20" Offset="0" />
                                                    <GradientStop Color="#FF00A400" Offset="1" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter Property="Panel.ZIndex" Value="5" />
                                        <Setter TargetName="Root" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect BlurRadius="8" ShadowDepth="5" Direction="315" Opacity="0.32" Color="Black" />
                                            </Setter.Value>
                                        </Setter>
                                        <Setter TargetName="Root" Property="Background">
                                            <Setter.Value>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#FF20CE20" Offset="0" />
                                                    <GradientStop Color="#FF00A400" Offset="1" />
                                                </LinearGradientBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="{StaticResource MetroTilePressedBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Grid.Resources>
            <Rectangle Fill="#FF6E6410" />
            <Image Source="{Binding SelectedGame.BackgroundArtPath, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=1280}"
                   Stretch="UniformToFill"
                   Opacity="0.46"
                   RenderOptions.BitmapScalingMode="HighQuality" />
            <Rectangle Fill="#AA1A1F12" />
            <Rectangle IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#663D3400" Offset="0" />
                        <GradientStop Color="#33000000" Offset="0.5" />
                        <GradientStop Color="#AA000000" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <StackPanel Orientation="Horizontal" Margin="152,122,0,0" HorizontalAlignment="Left" VerticalAlignment="Top">
                <TextBlock Text="overview" Foreground="White" FontFamily="Segoe UI Light" FontSize="32" FontWeight="Light" Margin="0,0,48,0" />
                <TextBlock Text="details" Foreground="#88FFFFFF" FontFamily="Segoe UI Light" FontSize="32" FontWeight="Light" Margin="0,0,48,0" />
                <TextBlock Text="extras" Foreground="#88FFFFFF" FontFamily="Segoe UI Light" FontSize="32" FontWeight="Light" Margin="0,0,48,0" />
                <TextBlock Text="gallery" Foreground="#88FFFFFF" FontFamily="Segoe UI Light" FontSize="32" FontWeight="Light" />
            </StackPanel>

            <TextBlock Text="{Binding SelectedGame.Title}"
                       Foreground="White"
                       FontFamily="Segoe UI Light"
                       FontSize="34"
                       FontWeight="Light"
                       Width="360"
                       TextAlignment="Right"
                       TextTrimming="CharacterEllipsis"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Margin="0,94,118,0" />

            <Grid Width="760" Height="382" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="160,184,0,0" ClipToBounds="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="165" />
                    <ColumnDefinition Width="165" />
                    <ColumnDefinition Width="330" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="100" />
                    <RowDefinition Height="100" />
                    <RowDefinition Height="162" />
                </Grid.RowDefinitions>

                <Button x:Name="SteamDetailsLaunchButton"
                        Grid.Row="0" Grid.Column="0"
                        Content="Launch"
                        Style="{StaticResource GameDetailsTileButtonStyle}"
                        Command="{Binding LaunchGameCommand}"
                        CommandParameter="{Binding SelectedGame}"
                        Visibility="{Binding SelectedGame.IsSteamGame, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button x:Name="SteamDetailsStoreButton"
                        Grid.Row="0" Grid.Column="1"
                        Content="Open in Store"
                        Margin="4,0,0,0"
                        Style="{StaticResource GameDetailsTileButtonStyle}"
                        Command="{Binding OpenSelectedGameStoreCommand}"
                        Visibility="{Binding SelectedGame.IsSteamGame, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button x:Name="SteamDetailsRateButton"
                        Grid.Row="1" Grid.Column="0"
                        Content="Rate"
                        Margin="0,4,0,0"
                        Style="{StaticResource GameDetailsTileButtonStyle}"
                        Visibility="{Binding SelectedGame.IsSteamGame, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button x:Name="SteamDetailsPinButton"
                        Grid.Row="1" Grid.Column="1"
                        Content="Pin to Tray"
                        Margin="4,4,0,0"
                        Style="{StaticResource GameDetailsTileButtonStyle}"
                        Command="{Binding SetOpenTrayGameCommand}"
                        Visibility="{Binding SelectedGame.IsSteamGame, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button x:Name="ManualDetailsLaunchButton"
                        Grid.Row="0" Grid.Column="0"
                        Content="Launch"
                        Style="{StaticResource GameDetailsTileButtonStyle}"
                        Command="{Binding LaunchGameCommand}"
                        CommandParameter="{Binding SelectedGame}"
                        Visibility="{Binding SelectedGame.IsManualGame, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button x:Name="ManualDetailsPinButton"
                        Grid.Row="0" Grid.Column="1"
                        Content="Pin to Tray"
                        Margin="4,0,0,0"
                        Style="{StaticResource GameDetailsTileButtonStyle}"
                        Command="{Binding SetOpenTrayGameCommand}"
                        Visibility="{Binding SelectedGame.IsManualGame, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                        Margin="8,0,0,0"
                        Background="#FF008A00"
                        BorderBrush="#44000000"
                        BorderThickness="1">
                    <Grid>
                        <Border Margin="8" RenderOptions.BitmapScalingMode="HighQuality">
                            <Border.Background>
                                <MultiBinding Converter="{StaticResource GameCoverBrushConverter}">
                                    <Binding Path="SelectedGame.CoverArtPath" />
                                    <Binding Path="GameCoverFitMode" />
                                    <Binding Path="SelectedGame.CoverZoom" />
                                    <Binding Path="SelectedGame.CoverOffsetX" />
                                    <Binding Path="SelectedGame.CoverOffsetY" />
                                </MultiBinding>
                            </Border.Background>
                        </Border>
                        <Image Source="{Binding SelectedGame.DetailsStoreImagePath, Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=420}"
                               Stretch="UniformToFill"
                               Margin="8"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                    </Grid>
                </Border>
                <StackPanel Grid.Row="2" Grid.Column="2" Margin="8,5,0,0" Width="315" ClipToBounds="False">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="{Binding SelectedGame.DetailsReviewStarsText}" Foreground="#FF00A000" FontSize="17" FontWeight="Bold" />
                        <TextBlock Text="{Binding SelectedGame.DetailsReviewCountText}" Foreground="White" FontSize="15" Margin="8,1,0,0" />
                    </StackPanel>
                    <TextBlock Text="{Binding SelectedGame.DetailsPlaytimeText}" Foreground="White" FontSize="15" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SelectedGame.DetailsGenreText}" Foreground="White" FontSize="16" Margin="0,5,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SelectedGame.DetailsMultiplayerText}" Foreground="White" FontSize="14" Margin="0,5,0,0" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SelectedGame.DetailsCoOpText}" Foreground="White" FontSize="14" Margin="0,2,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </Grid>

            <StackPanel Width="310" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,188,94,0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="54" Height="70" Background="#E8FFFFFF" BorderBrush="#AAFFFFFF" BorderThickness="1" Margin="0,0,18,0">
                        <TextBlock Text="{Binding SelectedGame.DetailsRatingLabel}" Foreground="#FF2D2D2D" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="{Binding SelectedGame.DetailsRatingDescription}"
                               Foreground="White"
                               FontSize="18"
                               Width="215"
                               TextWrapping="Wrap" />
                </StackPanel>

                <TextBlock Text="Source" Foreground="#AAFFFFFF" FontSize="18" Margin="0,48,0,0" />
                <TextBlock Text="{Binding SelectedGame.DetailsSourceText}" Foreground="White" FontSize="22" TextWrapping="Wrap" />
                <TextBlock Text="Genre" Foreground="#AAFFFFFF" FontSize="18" Margin="0,26,0,0" />
                <TextBlock Text="{Binding SelectedGame.DetailsGenreText}" Foreground="White" FontSize="22" TextWrapping="Wrap" />
                <TextBlock Text="Last played" Foreground="#AAFFFFFF" FontSize="18" Margin="0,26,0,0" />
