<UserControl x:Class="XboxMetroLauncher.Views.Tabs.SocialTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Canvas x:Name="DashboardCanvas" Width="1280" Height="502" ClipToBounds="True" HorizontalAlignment="Left" VerticalAlignment="Top">
            <StackPanel Canvas.Left="-40" Canvas.Top="72" Opacity="0.72" Visibility="Collapsed">
                <Button Width="138" Height="222" Style="{StaticResource X360TileButtonStyle}">
                    <Grid Background="#FFE43333">
                        <TextBlock Text="NETFLIX" Foreground="White" FontSize="25" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </StackPanel>

            <Canvas x:Name="HomeAlignedFrame" Canvas.Left="198" Canvas.Top="11" Width="764" Height="368" ClipToBounds="False">
                <Canvas x:Name="SocialArtLayer" Canvas.Left="0" Canvas.Top="0" Width="764" Height="368" IsHitTestVisible="False">
                    <Image Canvas.Left="535"
                           Canvas.Top="78"
                           Width="230"
                           Height="168"
                           Source="{Binding Source='Assets/Tiles/Social/join_the_fun_text.png', Converter={StaticResource CropImageSourceConverter}, ConverterParameter='294;102;782;594'}"
                           Stretch="Uniform"
                           Opacity="0.82"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <Image Canvas.Left="219"
                           Canvas.Top="87"
                           Width="300"
                           Height="256"
                           Source="{Binding Source='Assets/Tiles/Social/transparent_avatars.png', Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=384}"
                           Stretch="Uniform"
                           Opacity="0.96"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Canvas>

                <Canvas x:Name="ContentTileLayer" Canvas.Left="0" Canvas.Top="0" Width="764" Height="368">
                    <Button Canvas.Left="0"
                            Canvas.Top="0"
                            Width="177"
                            Height="122"
                            Style="{StaticResource X360TileButtonStyle}"
                            Command="{Binding Shell.OpenFriendsOverlayCommand}">
                        <Grid Background="#FF60B616">
                            <Image Source="{Binding Source='Assets/Tiles/Social/friends.png', Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=128}"
                                   Width="58"
                                   Height="58"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,-15,0,0" />
                            <TextBlock Text="Friends" Foreground="White" FontSize="13" Margin="6,0,0,8" VerticalAlignment="Bottom" />
                        </Grid>
                    </Button>
                    <Button Canvas.Left="0"
                            Canvas.Top="123"
                            Width="177"
                            Height="122"
                            Style="{StaticResource X360TileButtonStyle}"
                            Command="{Binding Shell.OpenThemeMenuCommand}">
                        <Grid Background="#FF60B616">
                            <Image Source="{Binding Source='Assets/Misc/SettingsIcons/preferences.png', Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=128}"
                                   Width="58"
                                   Height="58"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,-15,0,0" />
                            <TextBlock Text="Themes" Foreground="White" FontSize="13" Margin="6,0,0,8" VerticalAlignment="Bottom" />
                        </Grid>
                    </Button>
                    <Button Canvas.Left="0" Canvas.Top="246" Width="177" Height="122" Style="{StaticResource X360TileButtonStyle}">
                        <Grid Background="#FF60B616">
                            <Image Source="{Binding Source='Assets/Tiles/Social/sign_in_or_out.png', Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=128}"
                                   Width="58"
                                   Height="58"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,-15,0,0" />
                            <TextBlock Text="Sign in or Out" Foreground="White" FontSize="13" Margin="6,0,0,8" VerticalAlignment="Bottom" />
                        </Grid>
                    </Button>
                </Canvas>
            </Canvas>

            <StackPanel Canvas.Left="1115" Canvas.Top="11" Opacity="0.72" Visibility="Collapsed">
                <Button Width="72" Height="75" Style="{StaticResource X360TileButtonStyle}">
                    <Grid Background="#FF60B616"><TextBlock Text="TV" Foreground="White" FontSize="13" Margin="6,0,0,8" VerticalAlignment="Bottom" /></Grid>
                </Button>
                <Button Width="72" Height="75" Margin="0,1,0,0" Style="{StaticResource X360TileButtonStyle}">
                    <Grid Background="#FF60B616"><TextBlock Text="Program&#x0a;Guide" Foreground="White" FontSize="13" Margin="6,0,0,8" VerticalAlignment="Bottom" /></Grid>
                </Button>
            </StackPanel>
        </Canvas>
    </Grid>
</UserControl>
