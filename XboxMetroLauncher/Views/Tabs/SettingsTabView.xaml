<UserControl x:Class="XboxMetroLauncher.Views.Tabs.SettingsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Canvas x:Name="DashboardCanvas" Width="1280" Height="502" ClipToBounds="True" HorizontalAlignment="Left" VerticalAlignment="Top">
            <StackPanel Canvas.Left="-16" Canvas.Top="62" Opacity="0.42" Visibility="Collapsed">
                <Button Width="160" Height="142" Style="{StaticResource X360TileButtonStyle}">
                    <Grid Background="#FF1E1E1E" />
                </Button>
            </StackPanel>

            <Canvas x:Name="HomeAlignedFrame" Canvas.Left="198" Canvas.Top="41" Width="764" Height="368" ClipToBounds="False">
                <Canvas x:Name="ContentTileLayer" Canvas.Left="0" Canvas.Top="0" Width="764" Height="368">
                    <UniformGrid Canvas.Left="138" Canvas.Top="31" Width="286" Height="143" Columns="4" Rows="2"
                                 RenderTransformOrigin="0,0">
                        <UniformGrid.RenderTransform>
                            <ScaleTransform ScaleX="2.13" ScaleY="2.13" />
                        </UniformGrid.RenderTransform>
                    <Button Style="{StaticResource X360TileButtonStyle}" Command="{Binding Shell.OpenLauncherSettingsCommand}">
                        <Grid Background="#FF5EAE19">
                            <Image Source="{Binding Source='Assets/Misc/SettingsIcons/system.png', Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=96}" Width="39" Height="39" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-9,0,0" />
                            <TextBlock Text="System" Foreground="White" FontSize="10" Margin="5,0,0,5" VerticalAlignment="Bottom" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource X360TileButtonStyle}" Command="{Binding Shell.OpenLauncherSettingsCommand}">
                        <Grid Background="#FF5EAE19">
                            <Image Source="{Binding Source='Assets/Misc/SettingsIcons/preferences.png', Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=96}" Width="39" Height="39" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-9,0,0" />
                            <TextBlock Text="Preferences" Foreground="White" FontSize="9" Margin="4,0,0,5" VerticalAlignment="Bottom" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource X360TileButtonStyle}" Command="{Binding Shell.OpenProfileEditorCommand}">
                        <Grid Background="#FF5EAE19">
                            <Image Source="{Binding Source='Assets/Misc/SettingsIcons/account.png', Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=96}" Width="39" Height="39" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-9,0,0" />
                            <TextBlock Text="Profile" Foreground="White" FontSize="10" Margin="5,0,0,5" VerticalAlignment="Bottom" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource X360TileButtonStyle}" Command="{Binding Shell.OpenLauncherSettingsCommand}">
                        <Grid Background="#FF5EAE19">
                            <Image Source="{Binding Source='Assets/Misc/SettingsIcons/kinect.png', Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=96}" Width="41" Height="41" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-9,0,0" />
                            <TextBlock Text="Kinect" Foreground="White" FontSize="10" Margin="5,0,0,5" VerticalAlignment="Bottom" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource X360TileButtonStyle}" Opacity="0.42" Command="{Binding Shell.OpenLauncherSettingsCommand}">
                        <Grid Background="#FF5EAE19">
                            <Image Source="{Binding Source='Assets/Misc/SettingsIcons/account.png', Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=96}" Width="39" Height="39" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-9,0,0" />
                            <TextBlock Text="Account" Foreground="White" FontSize="10" Margin="5,0,0,5" VerticalAlignment="Bottom" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource X360TileButtonStyle}" Opacity="0.42" Command="{Binding Shell.OpenLauncherSettingsCommand}">
                        <Grid Background="#FF5EAE19">
                            <Image Source="{Binding Source='Assets/Misc/SettingsIcons/privacy.png', Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=96}" Width="39" Height="39" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-9,0,0" />
                            <TextBlock Text="Privacy" Foreground="White" FontSize="10" Margin="5,0,0,5" VerticalAlignment="Bottom" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource X360TileButtonStyle}" Command="{Binding Shell.OpenLauncherSettingsCommand}">
                        <Grid Background="#FF5EAE19">
                            <Image Source="{Binding Source='Assets/Misc/SettingsIcons/family.png', Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=96}" Width="39" Height="39" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-9,0,0" />
                            <TextBlock Text="Family" Foreground="White" FontSize="10" Margin="5,0,0,5" VerticalAlignment="Bottom" />
                        </Grid>
                    </Button>
                    <Button Style="{StaticResource X360TileButtonStyle}" Command="{Binding Shell.ShutdownCommand}">
                        <Grid Background="#FF5EAE19">
                            <Image Source="{Binding Source='Assets/Misc/SettingsIcons/turnoff.png', Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=96}" Width="40" Height="40" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-9,0,0" />
                            <TextBlock Text="Turn Off" Foreground="White" FontSize="10" Margin="5,0,0,5" VerticalAlignment="Bottom" />
                        </Grid>
                    </Button>
                    </UniformGrid>
                    <TextBlock Canvas.Left="138"
                               Canvas.Top="350"
                               Width="650"
                               Foreground="#88FFFFFF"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="Unofficial non-commercial fan project. Xbox and related names, logos, and imagery are property of Microsoft. Not affiliated with or endorsed by Microsoft." />
                </Canvas>
            </Canvas>

        </Canvas>
    </Grid>
</UserControl>
