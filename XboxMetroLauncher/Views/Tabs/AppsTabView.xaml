<UserControl x:Class="XboxMetroLauncher.Views.Tabs.AppsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Canvas x:Name="DashboardCanvas" Width="1280" Height="502" ClipToBounds="True" HorizontalAlignment="Left" VerticalAlignment="Top">
            <StackPanel Canvas.Left="-44" Canvas.Top="74" Opacity="0.72" Visibility="Collapsed">
                <Button Width="72" Height="73" Style="{StaticResource X360TileButtonStyle}">
                    <Grid Background="#FFD73535">
                        <TextBlock Text="Netflix" Foreground="White" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </StackPanel>

            <Canvas x:Name="HomeAlignedFrame" Canvas.Left="236" Canvas.Top="76" Width="806" Height="298" ClipToBounds="False">
                <Canvas x:Name="ContentTileLayer" Canvas.Left="0" Canvas.Top="0" Width="806" Height="298">
                    <Button Canvas.Left="0" Canvas.Top="0" Width="148" Height="148"
                            Style="{StaticResource X360TileButtonStyle}"
                            Command="{Binding Shell.OpenMyAppsCommand}">
                        <Grid Background="#FF60B616">
                            <Image Source="{Binding Source='Assets/Misc/myapps.png', Converter={StaticResource CropImageSourceConverter}, ConverterParameter='535;295;455;330'}"
                                   Stretch="Uniform"
                                   Width="72"
                                   Height="72"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,-18,0,0" />
                            <TextBlock Text="My Apps"
                                       Foreground="White"
                                       FontSize="22"
                                       Margin="12,0,0,12"
                                       VerticalAlignment="Bottom" />
                        </Grid>
                    </Button>
                    <Button Canvas.Left="0" Canvas.Top="150" Width="148" Height="148"
                            Style="{StaticResource X360TileButtonStyle}">
                        <Grid Background="#FF60B616">
                            <Image Source="{Binding Source='Assets/Tiles/Marketplace/apps_marketplace.png', Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=128}"
                                   Width="58"
                                   Height="58"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Top"
                                   Margin="0,26,0,0" />
                            <TextBlock Text="Browse&#x0a;Apps" Foreground="White" FontSize="22" Margin="12,0,0,12" VerticalAlignment="Bottom" />
                        </Grid>
                    </Button>

                    <Button Canvas.Left="150" Canvas.Top="0" Width="306" Height="298"
                            Style="{StaticResource X360TileButtonStyle}">
                        <Grid Background="Black" ClipToBounds="True">
                            <Image Source="{Binding Source='Assets/Tiles/hbogoapps.jpg', Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=512}"
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                            <Rectangle Fill="#33000000" />
                            <TextBlock Text="Watch with Xbox LIVE Gold" Foreground="#CCFFFFFF" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,24" />
                        </Grid>
                    </Button>

                    <Button Canvas.Left="458" Canvas.Top="0" Width="158" Height="148" Style="{StaticResource X360TileButtonStyle}">
                        <Grid Background="#FFE3262E" ClipToBounds="True">
                            <Image Source="{Binding Source='Assets/Tiles/netflixapps.png', Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=256}"
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                            <TextBlock Text="instant queue" Foreground="#CCFFFFFF" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,12" />
                        </Grid>
                    </Button>
                    <Button Canvas.Left="618" Canvas.Top="0" Width="188" Height="148" Style="{StaticResource X360TileButtonStyle}">
                        <Grid Background="#FF111111" ClipToBounds="True">
                            <Image Source="{Binding Source='Assets/Tiles/youtubeapps.jpg', Converter={StaticResource StringToImageSourceConverter}, ConverterParameter=320}"
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Grid>
                    </Button>
                    <Button Canvas.Left="458" Canvas.Top="150" Width="158" Height="148" Style="{StaticResource X360TileButtonStyle}">
                        <Grid Background="#FFF4F4F4">
                            <TextBlock Text="Hulu" Foreground="#FF58B22E" FontSize="31" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-12,0,0" />
                            <TextBlock Text="Plus" Foreground="#FF2E2E2E" FontSize="21" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,32,0,0" />
                        </Grid>
                    </Button>
                    <Button Canvas.Left="618" Canvas.Top="150" Width="188" Height="148" Style="{StaticResource X360TileButtonStyle}">
                        <Grid Background="White">
                            <TextBlock Text="ESPN" Foreground="#FFE03535" FontSize="39" FontStyle="Italic" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <TextBlock Text="LIVE SPORTS" Foreground="#FF9B1515" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,12" />
                        </Grid>
                    </Button>
                </Canvas>
            </Canvas>

            <StackPanel Canvas.Left="1210" Canvas.Top="74" Opacity="0.72" Visibility="Collapsed">
                <Button Width="151" Height="75" Style="{StaticResource X360TileButtonStyle}">
                    <Grid Background="#FF60B616">
                        <TextBlock Text="Profile" Foreground="White" FontSize="16" Margin="8,0,0,8" VerticalAlignment="Bottom" />
                    </Grid>
                </Button>
                <Button Width="151" Height="75" Margin="0,2,0,0" Style="{StaticResource X360TileButtonStyle}">
                    <Grid Background="#FF60B616">
                        <TextBlock Text="Settings" Foreground="White" FontSize="16" Margin="8,0,0,8" VerticalAlignment="Bottom" />
                    </Grid>
                </Button>
            </StackPanel>
        </Canvas>
    </Grid>
</UserControl>
