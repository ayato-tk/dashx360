                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsAddFriend}" Value="True">
                                                <Setter TargetName="FriendRow" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="AddFriendRow" Property="Visibility" Value="Visible" />
