                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="28" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="#FFE9EDEE"
                                        BorderBrush="#FFC0C8CA"
                                        BorderThickness="0,0,0,1">
