                                                           Text="{Binding Title}"
                                                           FontFamily="Segoe UI"
                                                           FontSize="20"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border Grid.Row="2"
                                        Background="#FFE9EDEE"
                                        BorderBrush="#FFC0C8CA"
                                        BorderThickness="0,1,0,0">
                                    <TextBlock Text="{Binding GuideMusicPickerCountText}"
                                               Margin="18,0,0,0"
                                               VerticalAlignment="Center"
                                               Foreground="#FF5E666A"
                                               FontSize="14" />
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid x:Name="FriendsListPanel"
                              Background="#FFE8EDEE"
