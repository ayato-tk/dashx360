                                                <TextBlock Text="{Binding ActiveFriendCountry}"
                                                           FontSize="21"
                                                           Foreground="White" />

                                                <Grid Grid.Row="1"
                                                      Margin="0,14,0,0"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Top">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="72" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Border Width="56"
                                                            Height="56"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Top"
                                                            Background="#EEF7F8F8"
                                                            BorderBrush="#66FFFFFF"
                                                            BorderThickness="1"
                                                            ClipToBounds="True">
                                                        <Image Source="{Binding ActiveFriendGameIconPath, Converter={StaticResource StringToImageSourceConverter}}"
                                                               Stretch="UniformToFill" />
                                                    </Border>

                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding ActiveFriendGameTitle}"
                                                               Width="300"
                                                               Margin="0,4,0,0"
                                                               Foreground="White"
                                                               FontSize="21"
                                                               TextWrapping="Wrap"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Grid>

                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding ActiveFriendStatus}"
                                                           FontSize="18"
                                                           Foreground="#FFF4F6F7"
                                                           VerticalAlignment="Bottom" />

                                                <StackPanel Grid.Row="2"
                                                            Orientation="Horizontal"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Bottom"
                                                            Margin="0,0,2,2">
                                                    <TextBlock Text="&#xE13D;" FontFamily="Segoe MDL2 Assets" Foreground="#79F2F5F6" FontSize="18" Margin="0,0,10,0" />
                                                    <TextBlock Text="&#xE13D;" FontFamily="Segoe MDL2 Assets" Foreground="#79F2F5F6" FontSize="18" Margin="0,0,10,0" />
                                                    <TextBlock Text="&#xE13D;" FontFamily="Segoe MDL2 Assets" Foreground="#79F2F5F6" FontSize="18" Margin="0,0,10,0" />
                                                    <TextBlock Text="&#xE13D;" FontFamily="Segoe MDL2 Assets" Foreground="#79F2F5F6" FontSize="18" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
                    <ContentControl Grid.Row="2"
                                    Style="{StaticResource GuideOverlayFooterStyle}"
                                    Visibility="{Binding IsMainGuideScreen, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>

                <Grid x:Name="GuideMusicOverlay"
                      Canvas.Left="0"
                      Canvas.Top="0"
                      Width="1280"
                      Height="720"
                      Panel.ZIndex="20"
                      Background="Transparent"
                      Visibility="{Binding IsGuideMusicPickerScreen, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Now Playing"
                               Foreground="#F2FFFFFF"
                               FontSize="32"
                               FontWeight="Light"
                               Margin="148,52,0,0" />

                    <Grid x:Name="GuideMusicContentGrid"
                          Width="880"
                          Height="482"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="440" />
                            <ColumnDefinition Width="440" />
                        </Grid.ColumnDefinitions>

                        <Border Background="#EEF0F2F1" />
                        <Border Grid.Column="1" Background="#D9AEB4B7" />

                        <StackPanel Margin="26,18,26,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Width="58" Height="38" Content="{Binding Dashboard.MusicPlayPauseText}" Background="#FF5EAE19" Foreground="White"
                                        Style="{StaticResource GuideMusicPlayerButtonStyle}" Command="{Binding Dashboard.PlayPauseMusicCommand}" />
                                <Button Width="58" Height="38" Content="Prev" Margin="5,0,0,0" Foreground="#FF333333" Background="#FFE8ECEC"
                                        Style="{StaticResource GuideMusicPlayerButtonStyle}" Command="{Binding Dashboard.PreviousMusicCommand}" />
                                <Button Width="58" Height="38" Content="Stop" Margin="5,0,0,0" Foreground="#FF333333" Background="#FFE8ECEC"
                                        Style="{StaticResource GuideMusicPlayerButtonStyle}" Command="{Binding Dashboard.StopMusicCommand}" />
                                <Button Width="58" Height="38" Content="Next" Margin="5,0,0,0" Foreground="#FF333333" Background="#FFE8ECEC"
                                        Style="{StaticResource GuideMusicPlayerButtonStyle}" Command="{Binding Dashboard.NextMusicCommand}" />
                                <Button Width="82" Height="38" Content="{Binding Dashboard.ShuffleText}" Margin="5,0,0,0" Foreground="#FF333333" Background="#FFE8ECEC"
                                        Style="{StaticResource GuideMusicPlayerButtonStyle}" Command="{Binding Dashboard.ToggleShuffleMusicCommand}" />
                            </StackPanel>

                            <TextBlock Text="Edit or Save Playlist" Foreground="#FF55595C" FontSize="22" Margin="0,20,0,14" />
                            <TextBlock Text="{Binding Dashboard.CurrentMusicTitle}" Foreground="#FF55595C" FontSize="21" TextTrimming="CharacterEllipsis" Margin="0,22,0,8" />
                            <Grid Height="44">
                                <Border Height="8" Background="#FFB5BABB" VerticalAlignment="Top" Margin="0,8,0,0" />
                                <ProgressBar Height="8" Minimum="0" Maximum="100" Value="{Binding Dashboard.MusicProgress}" Foreground="#FF6D7173" Background="Transparent" BorderThickness="0" VerticalAlignment="Top" Margin="0,8,0,0" />
                                <TextBlock Text="{Binding Dashboard.MusicPositionText}" Foreground="#FF55595C" FontSize="16" HorizontalAlignment="Left" VerticalAlignment="Bottom" />
                                <TextBlock Text="{Binding Dashboard.MusicDurationText}" Foreground="#FF55595C" FontSize="16" HorizontalAlignment="Right" VerticalAlignment="Bottom" />
                            </Grid>

                            <Grid Margin="0,24,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="128" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="96" />
                                </Grid.RowDefinitions>

                                <Border ClipToBounds="True">
                                    <controls:MusicVisualizer IsActive="{Binding Dashboard.IsMusicPlaying}"
                                                              Volume="{Binding Dashboard.MusicVolume}"
                                                              Progress="{Binding Dashboard.MusicProgress}"
                                                              Bass="{Binding Dashboard.VisualizerBass}"
                                                              Mid="{Binding Dashboard.VisualizerMid}"
                                                              Treble="{Binding Dashboard.VisualizerTreble}"
                                                              Loudness="{Binding Dashboard.VisualizerLoudness}"
                                                              Peak="{Binding Dashboard.VisualizerPeak}" />
                                </Border>

                                <Border Grid.Row="2" Background="#FFE2E5E4">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="Music Files" Foreground="#FF6B7174" FontSize="22" FontWeight="Light" HorizontalAlignment="Center" />
                                        <TextBlock Text="Assets\Custom Files\Music Files" Foreground="#FF7D8385" FontSize="13" Margin="0,6,0,0" HorizontalAlignment="Center" />
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                                            <TextBlock Text="{Binding Dashboard.MusicVolumeText, StringFormat=Volume {0}}" Foreground="#FF7D8385" FontSize="15" VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <Button Width="68" Height="28" Content="Vol -" Foreground="#FF333333" Background="#FFE8ECEC"
                                                    Style="{StaticResource GuideMusicPlayerButtonStyle}" Command="{Binding Dashboard.VolumeDownCommand}" />
                                            <Button Width="68" Height="28" Content="Vol +" Margin="8,0,0,0" Foreground="#FF333333" Background="#FFE8ECEC"
                                                    Style="{StaticResource GuideMusicPlayerButtonStyle}" Command="{Binding Dashboard.VolumeUpCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <Grid Grid.Column="1" Margin="0,12,0,0">
                            <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Dashboard.MusicTracks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Height="48"
                                                    Style="{StaticResource GuideMusicTrackButtonStyle}"
                                                    Command="{Binding DataContext.Dashboard.PlaySelectedMusicCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}">
                                                <Grid Background="#21FFFFFF">
                                                    <TextBlock Text="{Binding Title}" Foreground="#FF5F6669" FontSize="21" Margin="30,0,24,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="playing" Foreground="#FF5EAE19" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,18,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="{x:Type TextBlock}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock Text="{Binding Dashboard.MusicTrackCountText}" Foreground="#FF5F6669" FontSize="15" VerticalAlignment="Bottom" Margin="30,0,0,24" />
                        </Grid>
                    </Grid>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="145,0,0,58">
                        <Border Width="20" Height="20" CornerRadius="10" Background="#FF6CB344"><TextBlock Text="A" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                        <TextBlock Text=" Select   " Foreground="#E6FFFFFF" FontSize="16" />
                        <Border Width="20" Height="20" CornerRadius="10" Background="#FFD73A3A"><TextBlock Text="B" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                        <TextBlock Text=" Back   " Foreground="#E6FFFFFF" FontSize="16" />
                        <Grid Background="Transparent"
                              Cursor="Hand"
                              MouseLeftButtonUp="GuideMusicFullscreenHint_OnMouseLeftButtonUp">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="20" Height="20" CornerRadius="10" Background="#FF2574AA"><TextBlock Text="X" Foreground="White" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" /></Border>
                                <TextBlock Text=" Fullscreen Visualizer" Foreground="#E6FFFFFF" FontSize="16" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>

                <Grid Canvas.Left="404"
                      Canvas.Top="244"
                      Width="472"
                      Height="156"
                      Visibility="{Binding IsSocialMessageOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Background="#FF15191B"
                            BorderBrush="#FF5B6368"
                            BorderThickness="1,1,1,0"
                            Height="40"
                            VerticalAlignment="Top">
                        <TextBlock Text="{Binding SocialMessageTitle}"
                                   Margin="16,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   FontSize="18" />
                    </Border>
                    <Border Margin="0,40,0,0"
                            Background="#FFE8ECEE"
                            BorderBrush="#FF98A2A8"
                            BorderThickness="1">
                        <TextBlock Text="{Binding SocialMessageText}"
                                   Margin="24,0,24,0"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="#FF333638"
                                   FontSize="20" />
                    </Border>
                </Grid>

                <TextBlock Text="{Binding StatusText}"
                           Canvas.Left="477"
                           Canvas.Top="614"
                           Foreground="#CCFFFFFF"
                           FontSize="15"
                           Visibility="{Binding ShowStatusText, Converter={StaticResource BooleanToVisibilityConverter}}" />

            </Canvas>
        </Viewbox>
    </Grid>
</Window>

