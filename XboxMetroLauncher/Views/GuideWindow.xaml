                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource GuideKeyboardButtonStyle}"
                                                    MinWidth="86"
                                                    FontSize="14"
                                                    Command="{Binding DataContext.ActivateSearchKeyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Grid>

