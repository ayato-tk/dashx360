                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#FFF5F7F8" BorderBrush="#FFC0C8CA" BorderThickness="0,0,1,1">
