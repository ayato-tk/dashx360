<Window x:Class="XboxMetroLauncher.Views.GuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:XboxMetroLauncher.Controls"
        xmlns:input="clr-namespace:XboxMetroLauncher.Input"
        Width="1280"
        Height="720"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        PreviewKeyDown="Window_OnPreviewKeyDown"
        TextInput="Window_OnTextInput">
    <Grid x:Name="GuideRoot" Background="#E6000000">
        <Grid.Resources>
            <Style x:Key="GuideMediaTransportButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Width" Value="65" />
                <Setter Property="Height" Value="38" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="Foreground" Value="#FF34383A" />
                <Setter Property="Background" Value="#FFE9EEEE" />
                <Setter Property="BorderBrush" Value="#FFBBC3C6" />
                <Setter Property="BorderThickness" Value="0,0,1,0" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <TextBlock Text="{Binding Icon}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#FF008A00" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#FF008A00" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="BorderBrush" Value="White" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="GuideMediaSongRowButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Height" Value="42" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Foreground" Value="#FF34383A" />
                <Setter Property="Background" Value="#FFE5EAEB" />
                <Setter Property="BorderBrush" Value="#FFBBC3C6" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="19" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter Margin="18,0,13,0"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsMediaSongRowFocused}" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#FF008A00" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#FF008A00" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="BorderBrush" Value="White" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="GuideSubmenuItemStyle" TargetType="{x:Type ListBoxItem}">
                <Setter Property="Height" Value="38" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Foreground" Value="#FF333638" />
                <Setter Property="Background" Value="#FFE5EAEB" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                            <Border x:Name="Row"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#FFC0C8CA"
                                    BorderThickness="0,0,0,1">
                                <ContentPresenter HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Row" Property="Background" Value="#FF008A00" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="GuideFriendsRowStyle" TargetType="{x:Type ListBoxItem}">
                <Setter Property="Height" Value="52" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Foreground" Value="#FF1F2427" />
                <Setter Property="Background" Value="#FFF4F7F8" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                            <Border x:Name="Row"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#FFC8D0D3"
                                    BorderThickness="0,0,0,1">
                                <ContentPresenter HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Row" Property="Background" Value="#FF15A900" />
                                    <Setter TargetName="Row" Property="BorderBrush" Value="#FF15A900" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="GuidePartyRowStyle" TargetType="{x:Type ListBoxItem}">
                <Setter Property="Height" Value="44" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Foreground" Value="#FF202428" />
                <Setter Property="Background" Value="#FFF7F9FA" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                            <Border x:Name="Row"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#FFC7CFD2"
                                    BorderThickness="0,0,0,1">
                                <ContentPresenter HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Row" Property="Background" Value="#FF84B300" />
                                    <Setter TargetName="Row" Property="BorderBrush" Value="#FF84B300" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                                <DataTrigger Binding="{Binding RowKind}" Value="Disabled">
                                    <Setter Property="Foreground" Value="#FF8F979C" />
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="GuideFriendProfileActionStyle" TargetType="{x:Type ListBoxItem}">
                <Setter Property="Height" Value="41" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Foreground" Value="#FF2A3033" />
                <Setter Property="Background" Value="#FFF1F4F5" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                            <Border x:Name="Row"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#FFC6CED1"
                                    BorderThickness="0,0,0,1">
                                <ContentPresenter HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Row" Property="Background" Value="#FF10A500" />
                                    <Setter TargetName="Row" Property="BorderBrush" Value="#FF10A500" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="GuideKeyboardButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Height" Value="34" />
                <Setter Property="Margin" Value="2" />
                <Setter Property="Foreground" Value="#FF34383A" />
                <Setter Property="Background" Value="#FFF0F3F4" />
                <Setter Property="BorderBrush" Value="#FFBFC7CA" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <TextBlock Text="{Binding Label}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#FF00A000" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#FF00A000" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="BorderBrush" Value="White" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="GuideSearchUtilityButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Height" Value="38" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Foreground" Value="#FF34383A" />
                <Setter Property="Background" Value="#FFF0F3F4" />
                <Setter Property="BorderBrush" Value="#FFBFC7CA" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#FF10A500" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#FF10A500" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="BorderBrush" Value="White" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="GuideSearchKeyboard360Style" TargetType="{x:Type Button}">
                <Setter Property="Height" Value="28" />
                <Setter Property="Margin" Value="1" />
                <Setter Property="Foreground" Value="#FF40474B" />
                <Setter Property="Background" Value="#FFF2F4F5" />
                <Setter Property="BorderBrush" Value="#FFA8B0B4" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <TextBlock Text="{Binding Label}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#FF83AF19" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#FF7AA318" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="BorderBrush" Value="White" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="GuideSearchUtility360Style" TargetType="{x:Type Button}">
                <Setter Property="Height" Value="58" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Foreground" Value="#FF3F464A" />
                <Setter Property="Background" Value="#FFF1F3F4" />
                <Setter Property="BorderBrush" Value="#FFB3BBC0" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="#FF83AF19" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="#FF7AA318" />
                                    <Setter Property="Foreground" Value="White" />
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="BorderBrush" Value="White" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="GuideFriendProfileOverlayActionStyle" TargetType="{x:Type ListBoxItem}">
                <Setter Property="Height" Value="44" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Foreground" Value="#FF2D3336" />
                <Setter Property="Background" Value="#FFF4F5F6" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                            <Border x:Name="Row"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#FFC8CFD2"
                                    BorderThickness="0,0,0,1">
                                <ContentPresenter HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Row" Property="Background" Value="#FF13A000" />
                                    <Setter TargetName="Row" Property="BorderBrush" Value="#FF13A000" />
                                    <Setter Property="Foreground" Value="White" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="GuideOverlayFooterStyle" TargetType="{x:Type ContentControl}">
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="Margin" Value="24,6,0,0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ContentControl}">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="20" Height="20" CornerRadius="10" Background="#FF61B13F" VerticalAlignment="Center">
                                        <TextBlock Text="A" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text=" Select" Foreground="#FFE8EAEB" FontSize="18" VerticalAlignment="Center" Margin="7,0,22,0" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="20" Height="20" CornerRadius="10" Background="#FFD63D3D" VerticalAlignment="Center">
                                        <TextBlock Text="B" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text=" Back" Foreground="#FFE8EAEB" FontSize="18" VerticalAlignment="Center" Margin="7,0,22,0" />
                                </StackPanel>
                                <Grid VerticalAlignment="Center"
                                      Visibility="{Binding ShowFooterXAction, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      MouseLeftButtonUp="FooterXHint_OnMouseLeftButtonUp">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Border Width="20" Height="20" CornerRadius="10" Background="#FF2574AA" VerticalAlignment="Center">
                                            <TextBlock Text="X" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="{Binding FooterXActionText}" Foreground="#FFE8EAEB" FontSize="18" VerticalAlignment="Center" Margin="7,0,22,0" />
                                    </StackPanel>
                                </Grid>
                                <StackPanel Orientation="Horizontal"
                                            Cursor="Hand"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding ShowFooterYAction, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            MouseLeftButtonUp="MinimizeDashboardHint_OnMouseLeftButtonUp">
                                    <Border Width="20" Height="20" CornerRadius="10" Background="#FFD8B830" VerticalAlignment="Center">
                                        <TextBlock Text="Y" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="{Binding FooterYActionText}" Foreground="#FFE8EAEB" FontSize="18" VerticalAlignment="Center" Margin="7,0,0,0" />
                                </StackPanel>
                            </StackPanel>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="GuideMusicPlayerButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Foreground" Value="#FF333333" />
                <Setter Property="Background" Value="#FFE8ECEC" />
                <Setter Property="BorderBrush" Value="#55FFFFFF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="FontSize" Value="17" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="4,0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="1">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="Background" Value="#FF5EAE19" />
                                    <Setter Property="BorderBrush" Value="White" />
                                    <Setter Property="BorderThickness" Value="2" />
                                    <Setter TargetName="Root" Property="Effect">
                                        <Setter.Value>
                                            <DropShadowEffect BlurRadius="14" ShadowDepth="0" Color="White" Opacity="0.35" />
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#FF3F8610" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style x:Key="GuideMusicTrackButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Padding" Value="0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Grid>
                                <ContentPresenter />
                                <Border x:Name="FocusFrame"
                                        BorderBrush="#FF5EAE19"
                                        BorderThickness="4"
                                        Opacity="0" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="FocusFrame" Property="Opacity" Value="1" />
                                    <Setter Property="Panel.ZIndex" Value="10" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Opacity" Value="0.82" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <Viewbox x:Name="GuideContent" Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
            <Viewbox.RenderTransform>
                <TranslateTransform x:Name="GuideContentOffset" Y="-8" />
            </Viewbox.RenderTransform>
            <Canvas Width="1280" Height="720">
                <TextBlock Text="Xbox Guide"
                           Canvas.Left="354"
                           Canvas.Top="165"
                           Foreground="#FFE8EAEB"
                           FontFamily="Segoe UI"
                           FontSize="23"
                           FontWeight="Light" />

                <Image Canvas.Left="607"
                       Canvas.Top="146"
                       Width="48"
                       Height="48"
                       Stretch="UniformToFill"
                       Source="{Binding GamerPicturePath, Converter={StaticResource StringToImageSourceConverter}}" />

                <StackPanel Canvas.Left="802" Canvas.Top="153" Orientation="Horizontal">
                    <Grid Width="32" Height="18" Margin="0,2,18,0">
                        <Border Width="25" Height="12" HorizontalAlignment="Left" VerticalAlignment="Center"
                                BorderBrush="#FFE1E5E6" BorderThickness="2" />
                        <Border Width="4" Height="8" HorizontalAlignment="Right" Margin="0,0,2,0"
                                Background="#FFE1E5E6" VerticalAlignment="Center" />
                        <Rectangle Width="16" Height="6" Fill="#FFE1E5E6" HorizontalAlignment="Left" Margin="4,0,0,0" />
                    </Grid>
                    <Ellipse Width="22" Height="22" Stroke="#FF5EA51B" StrokeThickness="2" Margin="0,0,14,0" />
                </StackPanel>
                <TextBlock Text="{Binding ClockText}"
                           Canvas.Left="777"
                           Canvas.Top="179"
                           Width="126"
                           TextAlignment="Center"
                           Foreground="#FFE8EAEB"
                           FontSize="21"
                           FontWeight="SemiBold" />

                <Grid Canvas.Left="314"
                      Canvas.Top="204"
                      Width="694"
                      Visibility="{Binding IsGuideBladeScreen, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="315" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="GuideBladePanel"
                          Grid.Row="0"
                          Width="694"
                          Height="315"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="GuideBladeOffset" />
                        </Grid.RenderTransform>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="58" />
                            <ColumnDefinition Width="490" />
                            <ColumnDefinition Width="53" />
                            <ColumnDefinition Width="45" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#FFBBC6CC"
                                BorderBrush="#FF9BA5AA"
                                BorderThickness="0,0,1,0"
                                MouseLeftButtonDown="LeftOuterTab_OnMouseLeftButtonDown">
                            <TextBlock Text="{Binding LeftOuterTabText}"
                                       Foreground="#FF4A555D"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.LayoutTransform>
