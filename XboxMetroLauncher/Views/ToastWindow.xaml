<Window x:Class="XboxMetroLauncher.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        SizeToContent="WidthAndHeight">
    <Border x:Name="ToastRoot"
            CornerRadius="25"
            Padding="10,8,26,8"
            Margin="14"
            Opacity="0"
            BorderBrush="#66FFFFFF"
            BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#F53A4045" Offset="0" />
                <GradientStop Color="#F51C2023" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Color="#FF000000" Opacity="0.6" />
        </Border.Effect>
        <StackPanel Orientation="Horizontal">
            <Border Width="34"
                    Height="34"
                    CornerRadius="17"
                    VerticalAlignment="Center"
                    Background="#FF5EAE19"
                    BorderBrush="#88FFFFFF"
                    BorderThickness="1">
                <TextBlock Text="&#xE119;"
                           FontFamily="Segoe MDL2 Assets"
                           Foreground="White"
                           FontSize="15"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
            <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
                <TextBlock x:Name="ToastTitle"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="ToastBody"
                           Foreground="#CCFFFFFF"
                           FontSize="12.5"
                           MaxWidth="380"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
